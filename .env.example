# =============================================================================
# CATS Docker Deployment — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.

# --- PostgreSQL ---
POSTGRES_DB=cats_db
POSTGRES_USER=cats_user
POSTGRES_PASSWORD=cats_password
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
SECRET_KEY=change-this-in-production-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
CORS_ORIGINS=http://localhost,http://localhost:3000
TIMEZONE=Asia/Kolkata
BACKEND_PORT=8000

# --- Frontend (nginx) ---
FRONTEND_PORT=80
