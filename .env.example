# =============================================================================
# CATS Docker Deployment — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.

# --- PostgreSQL ---
POSTGRES_DB=*******
POSTGRES_USER=*******
POSTGRES_PASSWORD=********
POSTGRES_PORT=******

# --- Backend (FastAPI) ---
SECRET_KEY=change-this-in-production-minimum-32-characters-long
ALGORITHM=******
ACCESS_TOKEN_EXPIRE_HOURS=******
TIMEZONE=****
BACKEND_PORT=*****

# --- Frontend (nginx) ---
FRONTEND_PORT=*****
